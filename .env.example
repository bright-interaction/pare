# Pare configuration. Copy the values you need into /opt/pare/.env (mode 600) on
# the host. Real secrets live in the Dockyard vault - never commit them.

# --- Required ---
PARE_DATABASE_URL=postgres://pare:changeme@pare-postgres:5432/pare?sslmode=disable
# 32-byte keys, base64. PARE_MASTER_KEY wraps per-company data keys (encrypts all
# identities, receipts, bank text). Keep an off-host escrow copy - losing it
# shreds the encrypted PII.
PARE_MASTER_KEY=base64_32_bytes_here

# --- MCP (AI assistant). Set both to enable POST /mcp ---
PARE_SHIELD_KEY=base64_32_bytes_here
PARE_MCP_KEY=min_16_char_org_key
# Optional: per-AI-write ceiling in ore (default 50000000 = 500 000 SEK). 0 = off.
#PARE_MCP_MAX_ORE=50000000

# --- PDF (usually the compose default is fine) ---
#PARE_GOTENBERG_URL=http://gotenberg:3000

# --- Email (invoices + reminders). No-op until HOST + FROM are set. ---
# Resend SMTP creds are in the Dockyard vault ("Resend SMTP"), from
# dev@brightinteraction.com. Set these to turn on Skicka / Paminn.
#PARE_SMTP_HOST=smtp.resend.com
#PARE_SMTP_PORT=587
#PARE_SMTP_USER=resend
#PARE_SMTP_PASS=re_xxx_from_vault
#PARE_SMTP_FROM=fakturor@brightinteraction.com
#PARE_SMTP_FROM_NAME=Bright Interaction
#PARE_SMTP_TLS=starttls

# --- Error reporting (injected by the Hephaestus deploy step; leave unset for dev) ---
#FLARE_DSN=

# --- Next-step integrations (code not built yet; documented targets) ---
# Bank feed (PSD2/open banking) - prefer an EU-sovereign provider:
#PARE_BANKDATA_SECRET_ID=       # GoCardless Bank Account Data / Enable Banking
#PARE_BANKDATA_SECRET_KEY=
# Payment gateway - EU-first (Mollie/Swish) over Stripe:
#PARE_MOLLIE_API_KEY=
#PARE_MOLLIE_WEBHOOK_SECRET=

# --- Local dev only ---
#PARE_INSECURE_COOKIES=1
#PARE_LOG_LEVEL=info
